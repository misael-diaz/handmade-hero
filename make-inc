CC = gcc

# at this point the flags (the defines) are used for development builds
CCOPT = -std=gnu99 \
	-DHANDMADE_DEV=1 \
	-DHANDMADE_INTERNAL=1 \
	-g \
	-Wall \
	-Wextra \
	-Wformat \
	-gdwarf-4 \
	-O0

LIBS =

# supported platforms: possible values (case sensitive): win32 and linux
PLATFORM = linux
